#!/bin/bash
#
# pre-push hook: Validates the codebase before pushing to remote.
#
# This hook runs 'make pre-commit' to ensure all validation checks pass
# before code is pushed. This catches issues before they reach CI.
#
# Checks performed:
#   - build    : Ensures all code compiles
#   - lint     : Static analysis and code quality (golangci-lint)
#   - test     : Unit tests
#   - generate : Ensures tfplugindocs are up to date
#
# To install this hook, run: make install-hooks
# To bypass this hook (emergency only), run: git push --no-verify
#

set -e

echo "Running pre-push validation (make pre-commit)..."
echo "This may take a few minutes. Use 'git push --no-verify' to bypass."
echo ""

make pre-commit

# Check if 'make generate' produced any uncommitted changes
if ! git diff --quiet; then
    echo ""
    echo "ERROR: 'make generate' produced uncommitted changes."
    echo "Please review the diff, stage the changes, and amend your commit:"
    echo "  git diff"
    echo "  git add -A"
    echo "  git commit --amend --no-edit"
    echo ""
    exit 1
fi

echo ""
echo "Pre-push validation passed."
